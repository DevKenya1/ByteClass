# === BYTECLASS .gitignore ===
# Do NOT commit any of the following

# ── Secrets & config ──────────────────────────────────
config/constants.php
.env
*.env
.env.*

# ── Uploaded user files ───────────────────────────────
uploads/profile_photos/*
uploads/course_images/*
uploads/announcements/*
uploads/contracts/*
uploads/certificates/*
!uploads/profile_photos/.gitkeep
!uploads/course_images/.gitkeep
!uploads/announcements/.gitkeep
!uploads/contracts/.gitkeep
!uploads/certificates/.gitkeep

# ── Logs ─────────────────────────────────────────────
logs/
*.log

# ── PHP dependencies ──────────────────────────────────
vendor/

# ── Legacy React/Vite frontend (not used) ─────────────
frontend/

# ── Root duplicate pages (use pages/public/ instead) ──
about.php
courses.php
course-detail.php

# ── OS & editor files ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Database ──────────────────────────────────────────
# Keep schema.sql and seeds.sql but NOT any data dumps
database/data_*.sql
database/backup_*.sql
*.sql.gz

# ── Certificates generated by mPDF ───────────────────
uploads/certificates/*.pdf

# ── Temp files ───────────────────────────────────────
tmp/
temp/
*.tmp
*.cache

# ── Keep these placeholder directories ───────────────
!uploads/profile_photos/.gitkeep
!uploads/course_images/.gitkeep
!.gitignore
